# VEOLY-AI — single-brand build
VITE_BRAND=veoly

# Supabase: set your project URL and anon key (defaults in supabaseClient.ts are placeholders until configured)
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=

# Optional: production bridge host (see services/bridgeServerService.ts)
# VITE_BRIDGE_PRODUCTION_URL=https://captcha.veoly-ai.com

# N8n automation (see services/n8nWebhookService.ts): JSON POST on signup / after successful ToyyibPay payment (access code for email)
# VITE_N8N_SIGNUP_WEBHOOK_URL=https://your-n8n.app/webhook/signup
# VITE_N8N_PAYMENT_SUCCESS_WEBHOOK_URL=https://your-n8n.app/webhook/payment-success
